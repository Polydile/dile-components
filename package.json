    "@vitest/browser-playwright": "^4.1.10",
    "lerna": "^9.0.5",
    "playwright": "^1.61.1",
    "vite": "^6.4.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@11ty/eleventy-plugin-vite": "^6.0.0",
    "@reduxjs/toolkit": "^2.8.2",
